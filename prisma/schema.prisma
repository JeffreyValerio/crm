// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  password          String?
  nombre            String?
  apellidos         String?
  role              String    @default("user")
  inviteToken       String?   @unique
  invitedAt         DateTime?
  invitedBy         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  clients           Client[]
  statusComments    StatusComment[]
  advances          Advance[]
  approvedAdvances  Advance[] @relation("AdvanceApprover")
  prospectos        Prospecto[]
  notifications     Notification[]
  userKpiMetas      UserKpiMeta[]
  teamLeadOf        Equipo[]        @relation("TeamLeadEquipos")
  equipoMiembros    EquipoMiembro[]
  extension         String?
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tipo      String   // 'VALIDACION' | 'VENTA'
  titulo    String
  mensaje   String
  clientId  String?
  leida     Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, leida])
}

model ProductType {
  id          String   @id @default(cuid())
  nombre      String   @unique
  descripcion String?
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  products    Plan[]
}

model Plan {
  id            String      @id @default(cuid())
  nombre        String
  descripcion   String?
  activo        Boolean      @default(true)
  productTypeId String?
  productType   ProductType? @relation(fields: [productTypeId], references: [id])
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  clients       Client[]
}

enum TipoIdentificacion {
  NACIONAL
  DIMEX
  PASAPORTE
  JURIDICA
}

enum ValidationStatus {
  EN_PROCESO_VALIDACION
  APROBADA
  REQUIERE_DEPOSITO
  NO_APLICA
  INCOBRABLE
  DEUDA_MENOR_ANIO
}

enum SaleStatus {
  PENDIENTE_INSTALACION
  INSTALADA
  CANCELADA
  NO_COMPLETO_FACEID
  CANCELADO_POR_COBERTURA
  CLIENTE_NO_PERMITE_INSTALACION
}

enum AdvanceStatus {
  PENDIENTE
  APROBADO
  RECHAZADO
  EN_COBRO
  COMPLETADO
}

enum PostpagoStatus {
  PENDIENTE_ACTIVACION
  ACTIVADA
  PENDIENTE_MENSAJERIA
}

model Client {
  id                    String             @id @default(cuid())
  tipo                  String             @default("FIBRA") // "FIBRA" | "POSTPAGO"
  // Fotos
  cedulaFrontalUrl      String?
  cedulaTraseraUrl      String?
  selfieUrl             String?
  simUrl                String?            // Postpago: foto del SIM
  simCedulaUrl          String?            // Postpago: foto SIM + cédula
  // Datos personales
  nombres               String
  apellidos             String
  tipoIdentificacion    TipoIdentificacion
  numeroIdentificacion  String
  fechaNacimiento       DateTime?
  stb                   Int?
  // Contacto
  email                 String?
  telefono              String?
  // Ubicación
  provincia             String
  canton                String
  distrito              String
  senasExactas          String
  coordenadasLat        String?
  coordenadasLng        String?
  // Técnico
  numeroMedidor         String?  @unique
  // Plan
  planId                String?
  plan                  Plan?              @relation(fields: [planId], references: [id])
  // Estados (Fibra)
  validationStatus      ValidationStatus?  @default(EN_PROCESO_VALIDACION)
  validationComment     String?
  saleStatus            SaleStatus?
  saleComment           String?
  formulario            String?
  // Estados (Postpago)
  postpagoStatus        PostpagoStatus?
  tipoPlanPostpago      String?          // "NUEVO" | "MIGRACION" | "PORTABILIDAD"
  // Metadatos
  createdBy             String
  creator               User               @relation(fields: [createdBy], references: [id])
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  instaladaAt           DateTime?
  assignedAt            DateTime?
  statusComments        StatusComment[]
}

model StatusComment {
  id            String   @id @default(cuid())
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tipo          String   // "VALIDACION" o "VENTA"
  estadoAnterior String?
  estadoNuevo   String
  comentario    String
  createdBy     String
  creator       User     @relation(fields: [createdBy], references: [id])
  createdAt     DateTime @default(now())
}

model Advance {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  monto           Decimal       // Monto solicitado en colones
  quincenas       Int           @default(1) // En cuántas quincenas se cobrará
  montoRestante   Decimal       // Monto que falta por cobrar
  estado          AdvanceStatus @default(PENDIENTE)
  observaciones   String?       // Observaciones de la solicitud
  aprobadoPor     String?
  aprobador       User?         @relation("AdvanceApprover", fields: [aprobadoPor], references: [id])
  aprobadoAt      DateTime?
  rechazadoAt     DateTime?
  completadoAt    DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([userId])
  @@index([estado])
}

model Prospecto {
  id                String   @id @default(cuid())
  // Datos de la orden
  nroOrden          String   @unique
  estado            String?
  prioridad         String?
  idCliente         String?  @unique
  contrato          String?
  contratoLigado    String?
  tipoOrden         String?
  tipoServicio      String?
  tipoAveria        String?
  motivo            String?
  descripcion       String?
  tecnico           String?
  usuarioCreador    String?
  usuarioEnvio      String?
  // Contacto
  cliente           String?
  contactoNombre    String?
  contactoApellido  String?
  telCelular        String?
  telInstalacion    String?
  telOficina        String?
  email             String?
  // Ubicación
  sucursal          String?
  despacho          String?
  provincia         String?
  canton            String?
  distrito          String?
  barrio            String?
  direccion         String?
  // Datos técnicos
  observaciones     String?
  banderaCable      String?
  banderaInternet   String?
  facturador        String?
  tap               String?
  placa             String?
  poste             String?
  latitud           String?
  longitud          String?
  // Contactación
  metodoContacto        String?
  totalContactos        Int       @default(0)
  ultimoContacto        DateTime?
  proveedorCompetidor   String?
  // Gestión interna
  observacionesInternas String?
  asignadoA         String?
  asignado          User?    @relation(fields: [asignadoA], references: [id])
  asignadoAt        DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([asignadoA])
  @@index([estado])
  @@index([cliente])
}

model Tipificacion {
  id               String   @id @default(cuid())
  valor            String   @unique
  etiqueta         String
  activa           Boolean  @default(true)
  orden            Int      @default(0)
  eliminaProspecto Boolean  @default(false)
  creaCliente      Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Equipo {
  id          String          @id @default(cuid())
  nombre      String          @unique
  teamLeadId  String?
  teamLead    User?           @relation("TeamLeadEquipos", fields: [teamLeadId], references: [id])
  miembros    EquipoMiembro[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model EquipoMiembro {
  id        String   @id @default(cuid())
  equipoId  String
  equipo    Equipo   @relation(fields: [equipoId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([equipoId, userId])
  @@unique([userId])
  @@index([equipoId])
}

model KpiMeta {
  id        String   @id @default(cuid())
  periodo   String   @unique // "YYYY-MM"
  meta      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExtensionStats {
  id                 String   @id @default(cuid())
  extension          String
  fecha              DateTime @db.Date
  respondido         Int      @default(0)
  perdidas           Int      @default(0)
  correoVoz          Int      @default(0)
  sinRespuesta       Int      @default(0)
  ocupado            Int      @default(0)
  alocSegundos       Float?
  llamadasEntrantes  Int      @default(0)
  duracionInboundSeg Int      @default(0)
  llamadasSalientes  Int      @default(0)
  duracionSalidaSeg  Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([extension, fecha])
  @@index([extension])
  @@index([fecha])
}

model UserKpiMeta {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  periodo   String   // "YYYY-MM"
  meta      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, periodo])
  @@index([userId])
}

model ApiKey {
  id            String    @id @default(cuid())
  keyHash       String    @unique
  label         String    @default("Power BI")
  totalRequests Int       @default(0)
  lastUsedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}